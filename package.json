{
  "name": "@apec-one/node-utils",
  "version": "1.0.0",
  "description": "Reusable Node utilities for APECOne (paths, dotenv helpers)",
  "license": "MIT",
  "author": "aarya11 <arpitarya@users.noreply.github.com>",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/arpitarya/node-utils"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib dev",
    "test": "rstest"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "APECOne",
    "node",
    "utils",
    "paths",
    "dotenv"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@rslib/core": "0.19.5",
    "@types/node": "25.2.1",
    "chalk": "5.6.2",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "dotenv": "17.2.4",
    "dotenv-expand": "12.0.3"
  }
}
